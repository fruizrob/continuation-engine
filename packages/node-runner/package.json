{
  "name": "@unwinder/node-runner",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/node-runner/src/index.js",
  "types": "./dist/node-runner/src/index.d.ts",
  "bin": {
    "unwinder": "./dist/node-runner/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/node-runner/src/index.d.ts",
      "default": "./dist/node-runner/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/node-runner/src/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/node-runner/test"
  },
  "dependencies": {
    "@unwinder/compiler": "0.1.0",
    "@unwinder/contracts": "0.1.0",
    "@unwinder/runtime": "0.1.0"
  }
}
