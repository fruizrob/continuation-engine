{
  "name": "continuation-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Continuation-based deterministic time-travel runtime and tooling",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run -ws --if-present build",
    "typecheck": "npm run -ws --if-present typecheck",
    "test": "npm run build && npm run -ws --if-present test",
    "lint": "npm run -ws --if-present lint",
    "fixtures:verify": "node ./fixtures/harness/verify-fixtures.mjs",
    "check": "npm run typecheck && npm run test",
    "golden:refresh": "npm run build && node ./scripts/refresh-node-runner-golden.mjs"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
